# ── SLACK ─────────────────────────────────────────────────────────────
# From your Slack App dashboard (api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# ── SUPABASE ──────────────────────────────────────────────────────────
# Use the SERVICE ROLE key (not anon) — needed for full read/write access
# Found in: Supabase → Project Settings → API → service_role key
SUPABASE_URL=https://vuyxxyupmozllzmfqlbo.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── ANTHROPIC ─────────────────────────────────────────────────────────
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── SLACK CHANNEL ─────────────────────────────────────────────────────
# The channel ID for #cs-trustpilot-reviews
# Right-click the channel in Slack → View channel details → scroll to bottom for ID
# Looks like: C0123456789
TP_CHANNEL_ID=your-channel-id-here
